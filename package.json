{
  "name": "ielts-telegram-bot",
  "version": "1.0.0",
  "description": "Telegram bot that rates IELTS Speaking & Writing with GPT-4o and NestJS",
  "license": "MIT",
    "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
