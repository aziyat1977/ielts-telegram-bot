    "start:prod": "node dist/main.js",
    "clean": "rimraf dist",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "^11.1.2",
    "@nestjs/core": "^11.1.2",
    "@nestjs/platform-express": "^11.1.2",
    "express": "^4.18.2",
    "openai": "^5.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "telegraf": "^4.16.3",
    "dotenv": "^16.4.5",
    "minimatch": "9.0.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.7",
    "@types/node": "^20.4.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "rimraf": "^5.0.1",
    "prettier": "^3.2.4"
  },
  "overrides": {
    "minimatch": "9.0.2",
    "brace-expansion": "1.1.11"
  }
}
