{
  "name": "ielts-telegram-bot",
  "version": "1.1.0",
  "description": "Telegram bot that rates IELTS Speaking & Writing with GPT-4o + NestJS",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "openai": "^5.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.7",
    "@types/express": "^4.17.17",
    "@types/node": "^20.4.2",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.4.0"
  },
  "overrides": {
    "minimatch": "9.0.2",
    "brace-expansion": "1.1.11"
  }
}